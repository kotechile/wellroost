---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getOverviewContent } from '../lib/overview';

const overview = await getOverviewContent();
---

<BaseLayout
	title="About | Gini Loh"
	description="Learn the mission, audience, and integrated strategy thesis behind Gini Loh."
>
	<link slot="head" rel="canonical" href={new URL('/about/', Astro.site).toString()} />
	<section class="pt-32">
		<p class="section-eyebrow">About Gini Loh</p>
		<h1 class="mt-4 max-w-4xl text-5xl font-bold tracking-tight text-white sm:text-6xl">
			One integrated resource for earning more, keeping more, and growing more
		</h1>
		<p class="mt-6 max-w-3xl text-lg leading-8 text-slate-400 font-mono">
			> {overview.mission}
		</p>
	</section>

	<section class="mt-12 grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
		<div class="panel-soft rounded-[2.2rem] border border-slate-800 bg-slate-900/40 p-8 shadow-2xl backdrop-blur-md">
			<p class="section-eyebrow text-cyan-400">Origin Story</p>
			<p class="mt-4 text-lg leading-8 text-slate-400 font-mono">> {overview.originStory}</p>
		</div>
		<div class="rounded-[2.2rem] border border-slate-800 bg-slate-950 p-8 relative overflow-hidden">
			<div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml;base64,')]"></div>
			<p class="section-eyebrow text-emerald-400 relative z-10">Brand Thesis</p>
			<div class="mt-4 grid gap-4 relative z-10">
				{overview.aboutSections.map((section) => (
					<div class="rounded-[1.6rem] border border-slate-800 bg-slate-900/50 p-5">
						<h2 class="text-2xl font-bold tracking-tight text-white">{section.title}</h2>
						<p class="mt-3 text-base leading-7 text-slate-400">{section.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="mt-12">
		<p class="section-eyebrow text-cyan-400">Audience</p>
		<div class="mt-4 grid gap-5 md:grid-cols-3">
			{overview.audience.map((segment) => (
				<article class="panel-soft rounded-[1.9rem] border border-slate-800 bg-slate-900/40 p-6 shadow-2xl backdrop-blur-md">
					<h2 class="text-2xl font-bold tracking-tight text-white">{segment.title}</h2>
					<p class="mt-3 text-base leading-7 text-slate-400 font-mono">> {segment.description}</p>
				</article>
			))}
		</div>
	</section>
</BaseLayout>
