---
import CategoryBento from '../components/CategoryBento.astro';
import HeroGlass from '../components/HeroGlass.astro';
import LatestPostsGrid from '../components/LatestPostsGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTopLevelCategories } from '../lib/categories';
import { getOverviewContent } from '../lib/overview';

const [topCategories, overview] = await Promise.all([getTopLevelCategories(), getOverviewContent()]);
---

<BaseLayout
	title="Gini Loh | Intelligence for Life's High-Stakes Choices"
	description="Stop searching for information. Start making decisions. Frameworks and data to optimize your wealth, home, and lifestyle."
>
	<link slot="head" rel="canonical" href={new URL('/', Astro.site).toString()} />
	<HeroGlass overview={overview} topCategories={topCategories} />

	<!-- Decision Tools Horizontal Belt -->
	<section class="mt-20">
		<p class="section-eyebrow mb-6">Decision Tools</p>
		<div class="grid gap-5 md:grid-cols-3">
			<a href="/tools/lease-break-calculator" class="group panel-soft flex flex-col p-6 rounded-2xl transition hover:border-cyan-500/50">
				<div class="flex items-center justify-between">
					<div class="p-2 bg-emerald-500/10 rounded-lg text-emerald-400">
						<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
					</div>
					<span class="font-mono text-xs text-slate-500 group-hover:text-cyan-400 transition">LIVE</span>
				</div>
				<h3 class="mt-4 text-lg font-semibold text-slate-200">Lease Break Calculator</h3>
				<p class="mt-2 text-sm text-slate-400">Estimate the cost of leaving a lease early across flat-fee, percentage, and months-of-rent clauses.</p>
			</a>
			
			<a href="/tools/" class="group panel-soft flex flex-col p-6 rounded-2xl transition hover:border-emerald-500/50">
				<div class="flex items-center justify-between">
					<div class="p-2 bg-blue-500/10 rounded-lg text-blue-400">
						<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
					</div>
					<span class="font-mono text-xs text-slate-500 group-hover:text-emerald-400 transition">QUEUE</span>
				</div>
				<h3 class="mt-4 text-lg font-semibold text-slate-200">Calculator Library</h3>
				<p class="mt-2 text-sm text-slate-400">Browse the new tools hub and the reusable calculator system that future Gini Loh utilities will share.</p>
			</a>
			
			<a href="/about/" class="group panel-soft flex flex-col p-6 rounded-2xl transition hover:border-blue-500/50">
				<div class="flex items-center justify-between">
					<div class="p-2 bg-purple-500/10 rounded-lg text-purple-400">
						<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
					</div>
					<span class="font-mono text-xs text-slate-500 group-hover:text-blue-400 transition">THESIS</span>
				</div>
				<h3 class="mt-4 text-lg font-semibold text-slate-200">Why Tools Matter</h3>
				<p class="mt-2 text-sm text-slate-400">See how the editorial strategy connects frameworks, calculators, and practical financial decisions.</p>
			</a>
		</div>
	</section>

	<CategoryBento categories={topCategories} />
	
	<LatestPostsGrid />

	<!-- Vertical Hand-off Section -->
	<section class="mt-32 overflow-hidden rounded-[2rem] border border-slate-800 bg-slate-900 shadow-2xl relative">
		<div class="grid lg:grid-cols-2">
			<!-- Left Side: Giniloh (Data) -->
			<div class="p-10 lg:p-16 flex flex-col justify-center relative bg-[radial-gradient(ellipse_at_top_right,rgba(0,112,243,0.1),transparent_70%)]">
				<div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml;base64,')]"></div>
				<div class="relative z-10">
					<p class="font-mono text-xs text-cyan-400 uppercase tracking-widest mb-4">Phase 01</p>
					<h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Strategy is <span class="text-cyan-400">Giniloh.</span></h2>
					<p class="text-slate-400 text-lg mb-8">Data-driven blueprints, exact specifications, and capital allocation frameworks designed to maximize the ROI of your environment.</p>
					
					<div class="space-y-3 font-mono text-sm text-slate-500">
						<div class="flex justify-between border-b border-slate-800 pb-2"><span>Target Acquisition</span><span class="text-emerald-400">Calculated</span></div>
						<div class="flex justify-between border-b border-slate-800 pb-2"><span>Capital Deployment</span><span class="text-emerald-400">Optimized</span></div>
						<div class="flex justify-between pb-2"><span>System Integration</span><span class="text-emerald-400">Ready</span></div>
					</div>
				</div>
			</div>
			
			<!-- Right Side: WellRoost (Execution) -->
			<div class="p-10 lg:p-16 flex flex-col justify-center bg-slate-950 relative border-l border-slate-800">
				<div class="absolute inset-0 bg-gradient-to-br from-emerald-900/20 to-transparent"></div>
				<div class="relative z-10">
					<p class="font-mono text-xs text-emerald-400 uppercase tracking-widest mb-4">Phase 02</p>
					<h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Execution is <span class="text-emerald-400">WellRoost.</span></h2>
					<p class="text-slate-400 text-lg mb-8">From strategic blueprint to physical reality. Transforming analytical models into high-end, systematized living spaces.</p>
					
					<a href="#" class="inline-flex items-center gap-3 bg-emerald-500 hover:bg-emerald-400 text-slate-950 px-6 py-3 rounded-lg font-bold transition-colors">
						Enter WellRoost
						<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
					</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
