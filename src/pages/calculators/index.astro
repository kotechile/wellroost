---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculatorTools } from '../../lib/calculators/metadata';
---

<BaseLayout
	title="Calculators | WellRoost"
	description="Free public calculators for renters, homeowners, and investors making expensive housing and remodeling decisions."
>
	<link slot="head" rel="canonical" href={new URL('/calculators/', Astro.site).toString()} />

	<section class="pt-24 sm:pt-32">
		<p class="text-sm font-semibold tracking-wide uppercase text-gray-500">Free calculators</p>
		<h1 class="mt-4 max-w-4xl text-5xl font-bold tracking-tight text-gray-1000 sm:text-6xl">
			Practical money tools for expensive decisions
		</h1>
		<p class="mt-6 max-w-3xl text-lg leading-8 text-gray-600">
			Start with the numbers. These public calculators are crawlable Astro pages with server-rendered
			titles, copy, and internal links, then React only where the input experience needs to update live.
		</p>
	</section>

	<section class="mt-16 grid gap-6 lg:grid-cols-3" aria-label="Calculator library">
		{calculatorTools.map((tool) => (
			<article class="flex h-full flex-col rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-gray-300 hover:shadow-md">
				<div class="flex items-center justify-between gap-4">
					<p class="text-xs font-semibold uppercase tracking-widest text-primary">{tool.status}</p>
					<span class="rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs font-medium uppercase tracking-wider text-gray-600">
						Calculator
					</span>
				</div>
				<h2 class="mt-6 text-2xl font-bold tracking-tight text-gray-1000">{tool.title}</h2>
				<p class="mt-3 text-xs font-semibold uppercase tracking-wider text-gray-500">{tool.utility}</p>
				<p class="mt-4 flex-1 text-sm leading-7 text-gray-600">{tool.description}</p>
				<a
					href={tool.href}
					class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-gray-1000 transition hover:text-gray-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
				>
					Open calculator
					<span aria-hidden="true">-></span>
				</a>
			</article>
		))}
	</section>
</BaseLayout>
