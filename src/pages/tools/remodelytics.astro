---
import CalculatorShell from '../../components/calculators/CalculatorShell.astro';
import RemodelyticsPlatform from '../../components/calculators/react/RemodelyticsPlatform';
import BaseLayout from '../../layouts/BaseLayout.astro';

const acronym = (term: string, description: string) =>
	`<abbr title="${description}" class="cursor-help underline decoration-dotted underline-offset-4">${term}</abbr>`;

const engineNotes = [
	{
		title: 'Localized cost scaling',
		body: `Applies city cost index and material-tier multipliers before any ${acronym('ROI', 'Return on Investment: gain or loss relative to the amount spent.')}, ${acronym('ARV', 'After-Repair Value: the estimated home value after the renovation is completed.')}, or leverage math runs.`
	},
	{
		title: 'Investor and lender lens',
		body: `Calculates comp ${acronym('ARV', 'After-Repair Value: the estimated home value after the renovation is completed.')}, 70% rule ${acronym('ARV', 'After-Repair Value: the estimated home value after the renovation is completed.')}, ${acronym('MAO', 'Maximum Allowable Offer: the highest price an investor should pay before repairs.')}, purchase ${acronym('LTV', 'Loan-to-Value ratio: the loan amount divided by the home value.')}, refinance ${acronym('LTV', 'Loan-to-Value ratio: the loan amount divided by the home value.')}, and ${acronym('CLTV', 'Combined Loan-to-Value: total debt secured by the home divided by the home value.')} from the same scenario.`
	},
	{
		title: 'Energy policy logic',
		body: `Models ${acronym('HEAR', 'High-Efficiency Electric Home Rebate program under the Inflation Reduction Act.')}, ${acronym('HOMES', 'Home Owner Managing Energy Savings rebate program under the Inflation Reduction Act.')}, and Section 25C incentive paths using household income, ${acronym('AMI', 'Area Median Income: the local midpoint household income used for program eligibility.')}, savings, and caps.`
	},
	{
		title: 'Over-improvement guardrails',
		body: `Flags ${acronym('NKBA', 'National Kitchen and Bath Association: used here as a remodeling budget guardrail reference.')}-style spend ratios, DIY concentration, ${acronym('DTI', 'Debt-to-Income ratio: monthly debt payments divided by monthly income.')} stress, and high combined leverage before a remodel looks artificially attractive.`
	}
];
---

<BaseLayout
	title="Remodelytics | Home Upgrade ROI Calculator | Gini Loh"
	description="Model remodel ROI, ARV, energy incentives, ADU income, and renovation-loan leverage in a multi-engine home upgrade analytics platform."
>
	<link slot="head" rel="canonical" href={new URL('/tools/remodelytics/', Astro.site).toString()} />

	<CalculatorShell
		eyebrow="Remodeling analytics"
		title="Remodelytics"
		description="A multi-engine home upgrade ROI and underwriting platform for homeowners, investors, and lenders who need remodel math that separates resale lift, energy savings, income, risk, and leverage."
	>
		<div slot="calculator">
			<RemodelyticsPlatform client:load />
		</div>

		<div slot="aside" class="grid gap-6">
			<article class="overflow-hidden rounded-[1.8rem] border border-cyan-500/20 bg-[linear-gradient(135deg,rgba(0,11,80,0.78),rgba(2,6,23,0.98)_70%,rgba(29,106,229,0.12))] p-6 shadow-[0_0_40px_rgba(34,211,238,0.08)]">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-200/80">PRD implementation</p>
				<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">
					Built as an API-ready first version
				</h2>
				<p class="mt-4 text-sm leading-7 text-slate-300">
					This release keeps the calculations local and transparent while shaping the interface around
					the future data broker: RSMeans or XactRemodel costs, <Fragment set:html={acronym('AVM', 'Automated Valuation Model: a computer-generated property value estimate.')} /> feeds, HUD <Fragment set:html={acronym('AMI', 'Area Median Income: the local midpoint household income used for program eligibility.')} />, EIA utility rates,
					and DSIRE or state rebate programs.
				</p>
				<div class="mt-6 rounded-[1.3rem] border border-white/10 bg-white/5 p-4">
					<p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-slate-500">
						Current data mode
					</p>
					<p class="mt-2 text-sm leading-7 text-slate-200">
						User-entered scenario assumptions with defensible default formulas. No external cost,
						valuation, rebate, or credit API is called yet.
					</p>
				</div>
			</article>

			<article class="panel-soft rounded-[1.8rem] border border-slate-800/90 bg-slate-900/45 p-6 shadow-2xl backdrop-blur-md">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-emerald-300/80">Core engines</p>
				<div class="mt-5 grid gap-4">
					{engineNotes.map((item) => (
						<div class="rounded-[1.2rem] border border-slate-800/80 bg-slate-950/55 p-4">
							<h2 class="text-base font-semibold text-white">{item.title}</h2>
							<p class="mt-2 text-sm leading-7 text-slate-400" set:html={item.body}></p>
						</div>
					))}
				</div>
			</article>

			<article class="panel-soft rounded-[1.8rem] border border-slate-800/90 bg-slate-900/45 p-6 shadow-2xl backdrop-blur-md">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-300/70">Formula stack</p>
				<div class="mt-4 rounded-[1.3rem] border border-slate-800/90 bg-slate-950/60 p-5 font-mono text-sm leading-7 text-slate-200">
					<p>Local cost = baseline × local <Fragment set:html={acronym('CCI', 'City Cost Index: a multiplier used to localize national construction costs.')} /> / baseline <Fragment set:html={acronym('CCI', 'City Cost Index: a multiplier used to localize national construction costs.')} /></p>
					<p class="mt-2"><Fragment set:html={acronym('MAO', 'Maximum Allowable Offer: the highest price an investor should pay before repairs.')} /> = <Fragment set:html={acronym('ARV', 'After-Repair Value: the estimated home value after the renovation is completed.')} /> × 70% − repair cost</p>
					<p class="mt-2"><Fragment set:html={acronym('CLTV', 'Combined Loan-to-Value: total debt secured by the home divided by the home value.')} /> = (mortgage balance + <Fragment set:html={acronym('HELOC', 'Home Equity Line of Credit: a revolving loan secured by home equity.')} />) / <Fragment set:html={acronym('ARV', 'After-Repair Value: the estimated home value after the renovation is completed.')} /></p>
					<p class="mt-2">Energy <Fragment set:html={acronym('NPV', 'Net Present Value: the value today of future savings after discounting.')} /> = discounted savings − net project cost</p>
				</div>
			</article>

			<article class="rounded-[1.8rem] border border-amber-400/15 bg-[linear-gradient(180deg,rgba(120,53,15,0.18),rgba(2,6,23,0.96))] p-6 shadow-[0_0_40px_rgba(245,158,11,0.08)]">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-amber-200/80">Planning note</p>
				<h2 class="mt-3 text-xl font-semibold text-white">Not a live appraisal or loan approval</h2>
				<p class="mt-3 text-sm leading-7 text-slate-300">
					Remodelytics is a scenario model. Actual valuation, rebates, lending eligibility, and tax
					outcomes depend on verified comps, program rules, documentation, and lender overlays.
				</p>
			</article>
		</div>
	</CalculatorShell>
</BaseLayout>
