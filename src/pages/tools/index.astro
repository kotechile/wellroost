---
import BaseLayout from '../../layouts/BaseLayout.astro';

const toolCards = [
	{
		title: 'Lease Break Calculator',
		href: '/tools/lease-break-calculator',
		status: 'Live',
		description:
			'Estimate early termination exposure across flat-fee, percentage, and months-of-rent lease structures.'
	},
	{
		title: 'Buy vs. Rent 2.0',
		href: '#',
		status: 'Queued',
		description:
			'Compare optionality, equity build, and cash-flow drag before you lock yourself into a property decision.'
	},
	{
		title: 'Renovation ROI Estimator',
		href: '#',
		status: 'Queued',
		description:
			'Pressure-test whether a home upgrade meaningfully compounds value or just creates expensive vanity spend.'
	}
];
---

<BaseLayout
	title="Decision Tools | Gini Loh"
	description="Interactive financial and decision-making tools built inside the Gini Loh editorial platform."
>
	<link slot="head" rel="canonical" href={new URL('/tools/', Astro.site).toString()} />

	<section class="pt-32">
		<p class="section-eyebrow">Interactive tools</p>
		<h1 class="mt-4 max-w-4xl text-5xl font-bold tracking-tight text-white sm:text-6xl">
			Decision-grade calculators for the moments that actually move money
		</h1>
		<p class="mt-6 max-w-3xl text-lg leading-8 text-slate-400">
			Gini Loh tools turn messy trade-offs into structured estimates you can pressure-test fast.
			Each calculator lives inside Astro for speed and SEO, with React islands only where real-time
			interactivity matters.
		</p>
	</section>

	<section class="mt-12 grid gap-5 lg:grid-cols-3">
		{toolCards.map((tool) => (
			<article class="panel-soft flex h-full flex-col rounded-[1.8rem] border border-slate-800/90 bg-slate-900/40 p-6 shadow-2xl backdrop-blur-md">
				<div class="flex items-center justify-between gap-4">
					<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-300/70">{tool.status}</p>
					<span class="rounded-full border border-slate-700/80 bg-slate-950/60 px-3 py-1 font-mono text-[0.68rem] uppercase tracking-[0.22em] text-slate-400">
						Calculator
					</span>
				</div>
				<h2 class="mt-6 text-2xl font-semibold tracking-tight text-white">{tool.title}</h2>
				<p class="mt-3 flex-1 text-sm leading-7 text-slate-400">{tool.description}</p>
				<a
					href={tool.href}
					class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-cyan-300 transition hover:text-cyan-200"
				>
					{tool.href === '#' ? 'Coming soon' : 'Open calculator'}
					<span aria-hidden="true">→</span>
				</a>
			</article>
		))}
	</section>
</BaseLayout>
