---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTopLevelCategories } from '../../lib/categories';

const topCategories = await getTopLevelCategories();
---

<BaseLayout
	title="Categories | Gini Loh"
	description="Explore Gini Loh's category architecture, sourced directly from WordPress."
>
	<link slot="head" rel="canonical" href={new URL('/categories/', Astro.site).toString()} />
	<section class="pt-32">
		<p class="section-eyebrow">Category Index</p>
		<h1 class="mt-4 max-w-4xl text-5xl font-bold tracking-tight text-white sm:text-6xl">
			The decision Infrastructure
		</h1>
		<p class="mt-6 max-w-3xl text-lg leading-8 text-slate-400 font-mono">
			> Live taxonomy modules sourced directly from WordPress and structured for fast editorial navigation.
		</p>
	</section>

	<section class="mt-12 grid gap-6">
		{
			topCategories.map((category) => (
				<article class="panel-soft rounded-[2.2rem] border border-slate-800 bg-slate-900/40 p-7 shadow-2xl backdrop-blur-md">
					<div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
						<div class="max-w-3xl">
							<p class="section-eyebrow text-cyan-400">Top-Level Pillar</p>
							<h2 class="mt-3 text-3xl font-bold tracking-tight text-white">
								<a href={`/categories/${category.slug}`} class="transition hover:text-cyan-400">
									{category.name}
								</a>
							</h2>
							<p class="mt-4 text-base leading-8 text-slate-400">
								{category.description || 'A core strategic area in the Gini Loh editorial system.'}
							</p>
						</div>
						<a href={`/categories/${category.slug}`} class="btn-secondary whitespace-nowrap">
							View category
						</a>
					</div>

					{category.children.length ? (
						<div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
							{category.children.map((child) => (
								<a
									href={`/categories/${child.slug}`}
									class="group rounded-[1.6rem] border border-slate-800 bg-slate-950/50 p-6 transition hover:-translate-y-1 hover:border-cyan-500/30 hover:shadow-[0_16px_35px_rgba(0,0,0,0.4)]"
								>
									<p class="font-mono text-[0.65rem] uppercase tracking-[0.22em] text-slate-500 group-hover:text-cyan-400 transition">Subcategory</p>
									<h3 class="mt-3 text-xl font-bold tracking-tight text-slate-100">{child.name}</h3>
									<p class="mt-3 text-sm leading-7 text-slate-400 font-mono">
										> {child.description || 'A specialized lens within this strategic pillar.'}
									</p>
								</a>
							))}
						</div>
					) : null}
				</article>
			))
		}
	</section>
</BaseLayout>
