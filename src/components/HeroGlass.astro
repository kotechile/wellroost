---
---

<section class="relative pt-32">
	<div class="absolute inset-x-0 top-0 -z-10 h-[34rem] bg-[radial-gradient(circle_at_top,rgba(0,112,243,0.15),transparent_58%)]"></div>
	<div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1fr_1fr]">
		<div class="flex flex-col z-10">
			<p class="section-eyebrow">The Decision Engine</p>
			<h1 class="mt-5 text-5xl font-bold tracking-tight text-white sm:text-6xl">
				Intelligence for Life’s High-Stakes Choices.
			</h1>
			<p class="mt-6 text-lg leading-8 text-slate-400">
				Stop searching for information. Start making decisions. Frameworks and data to optimize your wealth, home, and lifestyle.
			</p>
			<div class="mt-8 flex flex-col gap-4 sm:flex-row">
				<a href="/categories/" class="btn-primary">Explore Decision Frameworks</a>
				<a href="/about/" class="btn-secondary">Home Optimization → WellRoost</a>
			</div>
			
			<div class="mt-12 flex gap-8 border-t border-slate-800 pt-8">
				<div>
					<p class="text-3xl font-mono text-emerald-400 font-semibold">20+</p>
					<p class="mt-1 text-xs uppercase tracking-widest text-slate-500 font-mono">Active Frameworks</p>
				</div>
				<div>
					<p class="text-3xl font-mono text-cyan-400 font-semibold">3</p>
					<p class="mt-1 text-xs uppercase tracking-widest text-slate-500 font-mono">Core Pillars</p>
				</div>
				<div>
					<p class="text-3xl font-mono text-blue-400 font-semibold">Tools</p>
					<p class="mt-1 text-xs uppercase tracking-widest text-slate-500 font-mono">Action Hub</p>
				</div>
			</div>
		</div>

		<div class="relative w-full aspect-square max-w-lg mx-auto">
			<!-- Decision Matrix / UI Snippet Visualization -->
			<div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md rounded-xl border border-slate-700/50 shadow-2xl overflow-hidden flex flex-col">
				<div class="h-10 border-b border-slate-700/50 bg-slate-800/50 flex items-center px-4 gap-2">
					<div class="w-3 h-3 rounded-full bg-red-500/80"></div>
					<div class="w-3 h-3 rounded-full bg-amber-500/80"></div>
					<div class="w-3 h-3 rounded-full bg-emerald-500/80"></div>
					<div class="ml-4 font-mono text-xs text-slate-400 flex-1 text-center">decision_matrix.exe</div>
				</div>
				<div class="p-6 flex-1 flex flex-col gap-4">
					<div class="font-mono text-sm text-slate-300">
						<span class="text-blue-400">></span> Initializing Cost vs. Value Analysis...
					</div>
					<div class="grid grid-cols-2 gap-4 mt-2">
						<div class="border border-slate-700/50 rounded-lg p-4 bg-slate-800/30">
							<div class="text-xs font-mono text-slate-500 mb-1">CAPITAL ALLOCATION</div>
							<div class="text-xl font-mono text-emerald-400">+14.2%</div>
							<div class="text-[10px] uppercase tracking-wider text-slate-500 mt-2">Expected ROI</div>
						</div>
						<div class="border border-slate-700/50 rounded-lg p-4 bg-slate-800/30">
							<div class="text-xs font-mono text-slate-500 mb-1">SYSTEM EFFORT</div>
							<div class="text-xl font-mono text-cyan-400">Low</div>
							<div class="text-[10px] uppercase tracking-wider text-slate-500 mt-2">Friction Index</div>
						</div>
					</div>
					
					<div class="mt-4 flex-1 border border-slate-700/50 rounded-lg bg-slate-950/50 relative overflow-hidden">
						<!-- Fake Chart Lines -->
						<div class="absolute bottom-0 left-0 right-0 h-1/2 border-t border-dashed border-slate-700/50"></div>
						<div class="absolute bottom-1/4 left-0 right-0 h-1/4 border-t border-dashed border-slate-700/30"></div>
						
						<svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none">
							<path d="M0,80 Q50,70 100,50 T200,40 T300,10" fill="none" stroke="currentColor" class="text-emerald-500" stroke-width="2" />
							<path d="M0,90 Q50,85 100,80 T200,75 T300,60" fill="none" stroke="currentColor" class="text-slate-600" stroke-width="2" stroke-dasharray="4 4" />
						</svg>
						
						<div class="absolute bottom-2 right-4 font-mono text-xs text-emerald-400 bg-slate-900/80 px-2 py-1 rounded border border-emerald-900">
							Optimized
						</div>
					</div>
				</div>
			</div>
			
			<!-- Decorative elements -->
			<div class="absolute -right-6 -bottom-6 w-32 h-32 bg-blue-500/20 blur-3xl rounded-full"></div>
			<div class="absolute -left-6 top-1/2 w-24 h-24 bg-emerald-500/20 blur-2xl rounded-full"></div>
		</div>
	</div>
</section>
