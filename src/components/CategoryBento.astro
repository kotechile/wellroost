---
import type { CategoryRecord } from '../lib/categories';
import type { WordPressPost } from '../lib/wordpress';

interface Props {
	categories: CategoryRecord[];
	postsByCategory?: Record<string, WordPressPost[]>;
}

const { categories, postsByCategory = {} } = Astro.props;
const accentPresets = [
	{
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
		color: 'text-emerald-400',
		bg: 'bg-emerald-500/10'
	},
	{
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />',
		color: 'text-blue-400',
		bg: 'bg-blue-500/10'
	},
	{
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
		color: 'text-purple-400',
		bg: 'bg-purple-500/10'
	},
	{
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
		color: 'text-cyan-400',
		bg: 'bg-cyan-500/10'
	}
];

const featuredCategories = categories.slice(0, 3);
const activeCategory = featuredCategories[0] ?? null;

function truncate(value: string, maxLength = 170) {
	if (value.length <= maxLength) {
		return value;
	}

	return `${value.slice(0, maxLength).trim()}...`;
}
---

<section id="pillars" class="mt-24 scroll-mt-32">
	<div class="flex items-end justify-between gap-6">
		<div>
			<p class="section-eyebrow">Active Frameworks</p>
			<h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-100 sm:text-4xl">
				Three pillars plus the Tools Hub
			</h2>
		</div>
	</div>

	<div class="mt-8 grid gap-4 sm:grid-cols-2">
		{
			featuredCategories.map((category, index) => {
				const preset = accentPresets[index % accentPresets.length];
				const isActive = activeCategory?.slug === category.slug;
				const postCount = postsByCategory[category.slug]?.length ?? category.postCount ?? 0;
				
				return (
					<button
						type="button"
						id={`pillar-trigger-${category.slug}`}
						aria-pressed={isActive ? 'true' : 'false'}
						aria-controls={`pillar-posts-${category.slug}`}
						data-pillar-trigger={category.slug}
						data-active={isActive ? 'true' : 'false'}
						class="group relative flex min-h-48 cursor-pointer flex-col justify-between overflow-hidden rounded-[1.5rem] border border-slate-800 bg-slate-900/40 p-6 text-left transition duration-300 hover:-translate-y-1 hover:border-cyan-500/30 hover:shadow-2xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400 data-[active=true]:border-cyan-400/50 data-[active=true]:shadow-[0_0_42px_rgba(56,189,248,0.16)] backdrop-blur-md"
					>
						<!-- Technical Background Pattern -->
						<div class="absolute inset-0 opacity-[0.03] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+PHBhdGggZD0iTTAgMjBoMjBNMjAgMHYyMCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSIjZmZmIiBzdHJva2Utd2lkdGg9IjEiLz48L3N2Zz4=')]"></div>
						
						<div class="relative z-10 flex items-start justify-between">
							<div class={`p-3 rounded-xl ${preset.bg} ${preset.color}`}>
								<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={preset.icon} />
							</div>
							<p class="font-mono text-[0.65rem] uppercase tracking-widest text-slate-500">
								POSTS.{postCount}
							</p>
						</div>
						
						<div class="relative z-10 mt-8">
							<h3 class="text-xl font-bold tracking-tight text-white group-hover:text-cyan-400 transition-colors">
								{category.name}
							</h3>
							<p class="mt-2 text-sm text-slate-400 font-mono">
								> {category.description || 'Live framework module sourced from the WordPress taxonomy.'}
							</p>
						</div>
						
						<div class="relative z-10 mt-6 flex items-center gap-2 text-xs font-mono text-slate-500">
							<span class="inline-flex h-2 w-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.8)]"></span>
							{postCount} Linked Posts
						</div>
					</button>
				);
			})
		}
		<a
			href="/calculators/"
			class="group relative flex min-h-48 flex-col justify-between overflow-hidden rounded-[1.5rem] border border-cyan-500/20 bg-[linear-gradient(135deg,rgba(14,165,233,0.16),rgba(15,23,42,0.5)_55%,rgba(16,185,129,0.12))] p-6 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:shadow-[0_0_40px_rgba(56,189,248,0.18)] backdrop-blur-md"
		>
			<div class="absolute inset-0 opacity-[0.04] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCI+PHBhdGggZD0iTTAgMjBoMjBNMjAgMHYyMCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSIjZmZmIiBzdHJva2Utd2lkdGg9IjEiLz48L3N2Zz4=')]"></div>

			<div class="relative z-10 flex items-start justify-between">
				<div class="rounded-xl bg-cyan-500/10 p-3 text-cyan-300">
					<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M7 4v6m10-6v6M6 14h4v4H6v-4Zm8 0h4v4h-4v-4Z" />
					</svg>
				</div>
				<p class="font-mono text-[0.65rem] uppercase tracking-widest text-cyan-300/70">TOOLS</p>
			</div>

			<div class="relative z-10 mt-8">
				<h3 class="text-xl font-bold tracking-tight text-white transition-colors group-hover:text-cyan-300">
					Calculator Hub
				</h3>
				<p class="mt-2 text-sm text-slate-300 font-mono">
					&gt; Lease break, remodeling ROI, and Remodelytics calculators you can run without hunting through the archive.
				</p>
			</div>

			<div class="relative z-10 mt-6 flex items-center gap-2 text-xs font-mono text-slate-400">
				<span class="inline-flex h-2 w-2 rounded-full bg-cyan-400 shadow-[0_0_8px_rgba(34,211,238,0.8)]"></span>
				Open calculators
			</div>
		</a>
	</div>

	<div id="pillar-results" class="mt-8 rounded-[1.7rem] border border-slate-800 bg-slate-900/45 p-5 shadow-2xl backdrop-blur-md sm:p-6">
		{
			featuredCategories.map((category) => {
				const posts = postsByCategory[category.slug] ?? [];
				const isActive = activeCategory?.slug === category.slug;

				return (
					<section
						id={`pillar-posts-${category.slug}`}
						aria-labelledby={`pillar-trigger-${category.slug}`}
						data-pillar-panel={category.slug}
						hidden={!isActive}
					>
						<div class="flex flex-col gap-3 border-b border-slate-800 pb-5 sm:flex-row sm:items-end sm:justify-between">
							<div>
								<p class="section-eyebrow text-cyan-400">Filtered Articles</p>
								<h3 class="mt-2 text-2xl font-bold tracking-tight text-white">
									{category.name}
								</h3>
							</div>
							<p class="font-mono text-xs uppercase tracking-widest text-slate-500">
								{posts.length} article{posts.length === 1 ? '' : 's'}
							</p>
						</div>

						{posts.length ? (
							<div class="mt-5 grid gap-4 lg:grid-cols-3">
								{posts.map((post) => (
									<a
										href={`/${post.slug}/`}
										class="group overflow-hidden rounded-[1.3rem] border border-slate-800 bg-slate-950/45 transition hover:-translate-y-1 hover:border-cyan-500/35 hover:shadow-[0_18px_40px_rgba(0,0,0,0.35)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400"
									>
										{post.featuredImage ? (
											<div class="aspect-video overflow-hidden border-b border-slate-800">
												<img
													src={post.featuredImage}
													alt={post.featuredImageAlt || ''}
													loading="lazy"
													class="h-full w-full object-cover opacity-70 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
												/>
											</div>
										) : null}
										<div class="p-5">
											<div class="flex items-center justify-between gap-3 font-mono text-[0.65rem] uppercase tracking-widest text-slate-500">
												<span class="text-cyan-400">{post.categoryLabel ?? category.name}</span>
												<span>{post.date ? new Date(post.date).toLocaleDateString() : 'Live'}</span>
											</div>
											<h4 class="mt-3 text-lg font-bold leading-tight text-white transition group-hover:text-cyan-100">
												{post.title}
											</h4>
											<p class="mt-3 text-sm leading-6 text-slate-400 font-mono">
												&gt; {post.excerpt ? truncate(post.excerpt) : 'Open the article for the full decision brief.'}
											</p>
										</div>
									</a>
								))}
							</div>
						) : (
							<p class="mt-5 rounded-[1.2rem] border border-slate-800 bg-slate-950/50 p-5 text-sm leading-7 text-slate-400 font-mono">
								&gt; No articles are currently published in this pillar.
							</p>
						)}
					</section>
				);
			})
		}
	</div>
</section>

<script>
	const triggers = Array.from(document.querySelectorAll<HTMLElement>('[data-pillar-trigger]'));
	const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-pillar-panel]'));
	const results = document.querySelector<HTMLElement>('#pillar-results');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	function selectPillar(slug: string) {
		for (const trigger of triggers) {
			const isActive = trigger.dataset.pillarTrigger === slug;
			trigger.dataset.active = isActive ? 'true' : 'false';
			trigger.setAttribute('aria-pressed', isActive ? 'true' : 'false');
		}

		for (const panel of panels) {
			panel.hidden = panel.dataset.pillarPanel !== slug;
		}

		results?.scrollIntoView({
			behavior: prefersReducedMotion ? 'auto' : 'smooth',
			block: 'start'
		});
	}

	for (const trigger of triggers) {
		trigger.addEventListener('click', () => {
			const slug = trigger.dataset.pillarTrigger;
			if (slug) {
				selectPillar(slug);
			}
		});
	}
</script>
