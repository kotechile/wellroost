---
import type { WordPressPost } from '../lib/wordpress';

interface Props {
	post: WordPressPost;
}

const { post } = Astro.props;

// Helper to generate a simulated decision metric based on title hash or length for visual consistency
const pseudoMetric = (title: string) => {
	const val = title.length % 3;
	if (val === 0) return { roi: '14.2%', effort: 'Low' };
	if (val === 1) return { roi: '8.5%', effort: 'Med' };
	return { roi: '21.0%', effort: 'High' };
};

const metric = pseudoMetric(post.title);
---

<article class="group h-full overflow-hidden rounded-xl border border-gray-200 bg-white transition duration-200 ease-out hover:-translate-y-1 hover:border-gray-300 hover:shadow-md">
	<a
		href={`/${post.slug}/`}
		class="flex h-full flex-col focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
	>
		{
			post.featuredImage && (
				<div class="h-48 overflow-hidden border-b border-gray-100 bg-gray-50">
					<img
						src={post.featuredImage}
						alt={post.featuredImageAlt || ''}
						loading="lazy"
						class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
					/>
				</div>
			)
		}
		
		<div class="flex flex-1 flex-col p-6">
			<div class="flex items-center justify-between gap-4 text-xs font-medium uppercase tracking-wider text-gray-500 mb-4 border-b border-gray-100 pb-3">
				<span class="text-primary">{post.categoryLabel ?? 'Brief'}</span>
				<span>{post.date ? new Date(post.date).toLocaleDateString() : 'REAL-TIME'}</span>
			</div>
			
			<h3 class="text-xl font-bold tracking-tight text-gray-1000 transition-colors leading-tight group-hover:text-primary">
				{post.title}
			</h3>
			
			<p class="mt-3 flex-1 text-sm leading-6 text-gray-600 line-clamp-3">
				{post.excerpt || 'Data points detected. Full analysis available in the WellRoost portal.'}
			</p>
			
			<div class="mt-6 flex items-center justify-between rounded-lg bg-gray-50 border border-gray-100 p-3 text-xs font-medium">
				<div>
					<span class="text-gray-500 uppercase tracking-wide">Exp. ROI:</span> 
					<span class="text-gray-1000 ml-1">{metric.roi}</span>
				</div>
				<div class="h-4 w-px bg-gray-200"></div>
				<div>
					<span class="text-gray-500 uppercase tracking-wide">Effort:</span> 
					<span class="text-gray-1000 ml-1">{metric.effort}</span>
				</div>
			</div>
		</div>
	</a>
</article>
